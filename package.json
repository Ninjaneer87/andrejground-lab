{
  "name": "andrejground-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel --color | grep --line-buffered '\\S'",
    "build:lab": "turbo run build --filter=@andrejground/lab",
    "build:site": "turbo run build --filter=site",
    "site": "pnpm --filter site start",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "turbo": "^2.6.3",
    "typescript": "~5.7.2",
    "vite": "^6.1.0"
  },
  "packageManager": "pnpm@9.15.4"
}
